# ---- App ----
APP_NAME=E-Room API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ---- Database (TiDB Local via Docker) ----
DATABASE_URL=mysql+pymysql://root:@tidb:4000/ERoom
DATABASE_URL_SYNC=mysql+pymysql://root:@tidb:4000/ERoom

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth ----
SECRET_KEY=change-me-in-production-use-a-real-random-key

# ---- LiveKit ----
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ---- TURN ----
TURN_SERVER_URL=turn:coturn:3478

# ---- MinIO ----
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ERoom
MINIO_SECURE=false

# ---- AI / LLM ----
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
NOMIC_API_KEY=nomic-your-key-here
ELEVENLABS_API_KEY=your-key-here
BRAVE_SEARCH_API_KEY=your-key-here
