# ─── E-Room Backend ──────────────────────────────────
# Copy this file to .env and fill in your values.
APP_NAME=E-Room API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ─── Database: TiDB Local (Docker) ────────────────────
# TiDB runs locally via Docker (pingcap/tidb:v8.5.0).
# Default: root user, no password, port 4000.
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=4000
DB_NAME=ERoom
DATABASE_URL=mysql+pymysql://root:@localhost:4000/ERoom
DATABASE_URL_SYNC=mysql+pymysql://root:@localhost:4000/ERoom

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth / JWT ─────────────────────────────────────
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI / LLM ──────────────────────────────────────
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL=google/gemma-4-e2b
LLM_API_KEY=
NOMIC_API_KEY=
BRAVE_SEARCH_API_KEY=

# ─── TTS (ElevenLabs) ──────────────────────────────
ELEVENLABS_API_KEY=

# ─── Stripe (Subscription) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── LiveKit (WebRTC) ──────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── TURN / coTURN ─────────────────────────────────
TURN_SERVER_URL=turn:localhost:3478

# ─── MinIO (Object Storage) ─────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ERoom
MINIO_SECURE=false

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=log/app.log

